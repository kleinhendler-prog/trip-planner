# ============= Application Configuration =============

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-minimum-32-characters

# ============= Supabase Configuration =============

# Public Supabase URL (can be used in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase Anon Key (can be used in browser)
# Limited access, respects Row Level Security (RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Supabase Service Role Key (SECRET - keep secure!)
# Bypasses RLS, only use on backend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============= Anthropic Configuration =============

# Anthropic API Key for Claude integration
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============= Google Places API =============

# Google Places API Key for location searches
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-key-here

# Google Maps API Key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# ============= Weather API =============

# OpenWeatherMap API Key for weather data
NEXT_PUBLIC_OPENWEATHER_API_KEY=your-openweathermap-key-here

# ============= Email Configuration =============

# Email provider (sendgrid, mailgun, resend, etc.)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-provider-key-here
EMAIL_FROM_ADDRESS=noreply@tripplanner.com
EMAIL_FROM_NAME=Trip Planner

# ============= Third-party Integrations =============

# Booking.com Affiliate ID
NEXT_PUBLIC_BOOKING_COM_AFFILIATE_ID=your-affiliate-id

# GetYourGuide Affiliate ID
NEXT_PUBLIC_GET_YOUR_GUIDE_AFFILIATE_ID=your-affiliate-id

# ============= Environment =============

# Node environment
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ============= Debugging =============

# Enable debug logs
DEBUG=false

# Enable verbose logging
VERBOSE_LOGS=false

# ============= Optional: Payment Processing =============

# Stripe Configuration (if you add payment features)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ============= Optional: Social Authentication =============

# Google OAuth (if you add social login)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (if you add social login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
